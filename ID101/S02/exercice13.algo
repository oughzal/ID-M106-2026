algorithme exercice13
variables
    n,i,s : entier
debut
    ecrire("Donner un nombre : ")
    lire(n)
    s=0
    pour i de 1 à n-1 faire
        si n % i == 0 alors
            s = s + i
        FinSi
    finpour
    si n == s alors
        ecrireln(n," est un nombre parfait")
    sinon
        ecrireln(n," n'est un nombre parfait")
    finSi

fin