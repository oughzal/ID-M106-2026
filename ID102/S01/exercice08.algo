algorithme NomAlgorithme

variables
    h,m,s,d : entier

debut
    // Entrée
    ecrire("heures : ")
    lire(h)
    ecrire("minutes : ")
    lire(m)
    ecrire("secondes : ")
    lire(s)
    ecrire("Duree en secondes : ")
    lire(d)
    ecrire(h,":",m,":",s,"+",d ,"sec = ")
    // Traitement
    s = s + d
    m = m + s div 60
    s = s % 60
    h = h + m div 60
    m = m % 60
    ecrireln(h,":",m,":",s)
fin