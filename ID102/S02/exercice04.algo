algorithme exercice4

variables
    a,b,c,d,x1,x2 : réel

debut
    ecrire("donner a : ")
    lire(a)
    ecrire("donner b : ")
    lire(b)
    ecrire("donner c : ")
    lire(c)

    d = b^2 - 4*a*c
    si d < 0 alors
        ecrire("pas de solution réelle")
    sinonSi d = 0 alors
        x1 = -b/(2*a)
        ecrire("solution double : ", x1)
    sinon
        x1 = (-b - racine(d))/(2*a)
        x2 = (-b + racine(d))/(2*a)
        ecrire("solutions : ", x1, " et ", x2)
    finSi
fin